# =============================================================================
# gercekveri.com — environment variables
# Copy to .env.local for development. Never commit real secrets.
# =============================================================================

# --- Database (Neon Postgres) -----------------------------------------------
# Get a free database at https://neon.tech — uses serverless Postgres.
# Use the pooled connection string (with ?pgbouncer=true) for the app,
# and the direct one for migrations.
DATABASE_URL="postgresql://user:password@ep-xxxxx-pooler.region.neon.tech/gercekveri?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxxxx.region.neon.tech/gercekveri?sslmode=require"

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="GerçekVeri"

# Used to hash IPs / fingerprints — generate with `openssl rand -hex 32`
HASH_SECRET="change-me-to-a-random-32-byte-hex-string"

# --- Upstash Redis (free tier) ----------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Upstash QStash (free tier) ---------------------------------------------
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# --- AI (Google Gemini, free tier) ------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=""

# --- Admin bootstrap --------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL=""
ADMIN_BOOTSTRAP_PASSWORD=""

# --- AdSense -----------------------------------------------------------------
# Format: ca-pub-XXXXXXXXXXXXXXXX (AdSense publisher ID).
# Boş bırakılırsa script yüklenmez (dev safe). Production'da Vercel
# environment'a ekle: Vercel Dashboard → Project → Settings → Environment Variables
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-1903288869126718"
